#!/usr/bin/env bash
set -u

# Colors
if [ -t 1 ]; then
    GREEN="\033[0;32m"
    RED="\033[0;31m"
    YELLOW="\033[1;33m"
    BLUE="\033[0;34m"
    BOLD="\033[1m"
    NC="\033[0m"
else
    GREEN=""
    RED=""
    YELLOW=""
    BLUE=""
    BOLD=""
    NC=""
fi

print_status() {
    local label="$1"
    local status="$2"
    local color="$3"
    printf "%-30s ${color}%s${NC}\n" "$label" "$status"
}

print_header() {
    echo
    echo -e "${BOLD}${BLUE}=== Running local Python checks ===${NC}"
}

print_header

mapfile -d '' files < <(git diff --cached --name-only --diff-filter=ACMR -z -- '*.py')

if [ ${#files[@]} -eq 0 ]; then
    print_status "Python files staged" "SKIPPED" "$YELLOW"
    exit 0
fi

echo "Files:"
for f in "${files[@]}"; do
    echo "  - $f"
done
echo

# 1. Ruff safe auto-fix
if ruff check --fix "${files[@]}"; then
    print_status "ruff check --fix" "PASSED" "$GREEN"
else
    print_status "ruff check --fix" "FAILED" "$RED"
    exit 1
fi

# 2. Ruff formatter
if ruff format "${files[@]}"; then
    print_status "ruff format" "PASSED" "$GREEN"
else
    print_status "ruff format" "FAILED" "$RED"
    exit 1
fi

# 3. Re-stage files after auto-fix/format
if git add -- "${files[@]}"; then
    print_status "git add (re-stage)" "PASSED" "$GREEN"
else
    print_status "git add (re-stage)" "FAILED" "$RED"
    exit 1
fi

# 4. Final verification
if ruff check "${files[@]}"; then
    print_status "ruff check" "PASSED" "$GREEN"
else
    print_status "ruff check" "FAILED" "$RED"
    exit 1
fi

if ruff format --check "${files[@]}"; then
    print_status "ruff format --check" "PASSED" "$GREEN"
else
    print_status "ruff format --check" "FAILED" "$RED"
    exit 1
fi

echo
echo -e "${GREEN}${BOLD}All staged Python checks passed.${NC}"
exit 0
